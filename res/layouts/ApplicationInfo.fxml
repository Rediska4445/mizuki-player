<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane style="-fx-background-color: #1e1e1e;" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="rf.ebanina.UI.Editors.Info.Application.ApplicationInfoController">

    <ScrollPane fx:id="scrollView" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent;" vbarPolicy="NEVER" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <content>
            <VBox fx:id="infoBox" maxWidth="Infinity" spacing="15" style="-fx-background-color: #1e1e1e;" VBox.vgrow="ALWAYS">

                <children>
                    <StackPane fx:id="imageBox" maxWidth="Infinity" VBox.vgrow="ALWAYS">
                        <children>
                            <ImageView fx:id="logo" fitWidth="300.0" pickOnBounds="true" preserveRatio="true" StackPane.alignment="CENTER">
                                <image>
                                    <Image url="@../visual/gui/mizuka-transparent.png" />
                                </image>
                            </ImageView>

                            <StackPane fx:id="gradientOverlay" maxHeight="Infinity" maxWidth="Infinity"
                                       style="-fx-background-color: radial-gradient(center 50% 0%, radius 95%, transparent 25%, #1e1e1e 100%);"
                                       StackPane.alignment="CENTER" VBox.vgrow="ALWAYS" />
                        </children>
                    </StackPane>
                      <VBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="6">
                          <children>
                              <Label style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="Mizuka" HBox.hgrow="ALWAYS" />
                              <Label style="-fx-text-fill: white; -fx-font-size: 12;" text="Медиаплеер с расширенными настройками интерфейса и эффектами анимации." HBox.hgrow="ALWAYS">
                                    </Label>
                          </children>
                          <VBox.margin>
                              <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                          </VBox.margin>
                      </VBox>

                </children>
            </VBox>
        </content>
    </ScrollPane>

</AnchorPane>
