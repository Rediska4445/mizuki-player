<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0">
    <modelVersion>4.0.0</modelVersion>
    <groupId>rf.ebanina</groupId>
    <artifactId>ebanina</artifactId>
    <version>1.4.9</version>
    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <build.output>out</build.output>

        <!-- Лицензии -->
        <license.path>${basedir}/../../../license</license.path>

        <!-- Кэш -->
        <cache.path>${basedir}/../../../cache</cache.path>

        <!-- Configuration -->
        <config.path>${basedir}/../../../config</config.path>

        <!-- Ресурсы -->
        <resources.path>${basedir}/../../../res</resources.path>

        <!-- Библиотеки -->
        <libs.path>${basedir}/../../../libraries</libs.path>

        <!-- Модульные библиотеки -->
        <libs.modules.path>${libs.path}/modules</libs.modules.path>

        <!-- Классовые библиотеки -->
        <libs.classes.path>${libs.path}/classes</libs.classes.path>

        <file.cache.path>${basedir}/../../../package/raw</file.cache.path>

        <!-- Пропуск тестов из сборщика (maven, нужен только для сборки, по написанной ниже причине) -->
        <maven.test.skip>true</maven.test.skip>

        <!-- Пропуск тестов -->
        <skipTests>true</skipTests>
    </properties>

    <!-- Локальный репозиторий -->
    <repositories>
        <repository>
            <id>local-repo</id>
            <url>file://${basedir}/../../libraries/modules/</url>
        </repository>
    </repositories>

    <!--
        Все зависимости, должны быть предварительно скачаны в папку libraries.
        Это всё потому, что некоторые зависимости отсутствуют в maven.
    -->
    <dependencies>
        <dependency>
            <groupId>commons-io</groupId>
            <artifactId>commons-io</artifactId>
            <version>2.6</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/commons-io-2.6.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>commons-logging</groupId>
            <artifactId>commons-logging</artifactId>
            <version>1.3.4</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/commons-logging-1.3.4.jar</systemPath>
        </dependency>

        <dependency>
            <groupId>javazoom</groupId>
            <artifactId>jlayer</artifactId>
            <version>1.0.1.4</version>
            <scope>system</scope>
            <systemPath>${libs.classes.path}/jlayer-1.0.1.4.jar</systemPath>
        </dependency>

        <dependency>
            <groupId>org.controlsfx</groupId>
            <artifactId>controlsfx</artifactId>
            <version>11.1.2</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/controlsfx-11.1.2.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-swt</artifactId>
            <version>21</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/javafx-swt.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-base</artifactId>
            <version>21</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/javafx.base.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-controls</artifactId>
            <version>21</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/javafx.controls.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-fxml</artifactId>
            <version>21</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/javafx.fxml.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-graphics</artifactId>
            <version>21</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/javafx.graphics.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-media</artifactId>
            <version>21</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/javafx.media.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-swing</artifactId>
            <version>21</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/javafx.swing.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>org.openjfx</groupId>
            <artifactId>javafx-web</artifactId>
            <version>21</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/javafx.web.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.jfoenix</groupId>
            <artifactId>jfoenix</artifactId>
            <version>9.0.10</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/jfoenix-9.0.10.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>net.java.dev.jna</groupId>
            <artifactId>jna</artifactId>
            <version>5.14.0</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/jna-5.14.0.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>net.java.dev.jna</groupId>
            <artifactId>jna-platform</artifactId>
            <version>5.14.0</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/jna-platform-5.14.0.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.github.kwhat.jnativehook</groupId>
            <artifactId>jnativehook</artifactId>
            <version>2.2.2</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/jnativehook-2.2.2.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>org.jsoup</groupId>
            <artifactId>jsoup</artifactId>
            <version>1.10.1</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/jsoup-1.10.1.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.github.lastfmjava</groupId>
            <artifactId>lastfm-java</artifactId>
            <version>0.1.2</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/lastfm-java-0.1.2.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.mpatric</groupId>
            <artifactId>mp3agic</artifactId>
            <version>0.9.1</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/mp3agic-0.9.1.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>untitled</groupId>
            <artifactId>untitled10</artifactId>
            <version>1.0</version>
            <scope>system</scope>
            <systemPath>${libs.modules.path}/untitled10.jar</systemPath>
        </dependency>

        <!-- Classes -->
        <dependency>
            <groupId>com.ebanina</groupId>
            <artifactId>ebanina-audio-player</artifactId>
            <version>1.0</version>
            <scope>system</scope>
            <systemPath>${libs.classes.path}/ebanina-audio-player.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.ebanina</groupId>
            <artifactId>ebanina-mod-api</artifactId>
            <version>1.0</version>
            <scope>system</scope>
            <systemPath>${libs.classes.path}/ebanina-mod-api.jar</systemPath>
        </dependency>

        <dependency>
            <groupId>com.jcraft</groupId>
            <artifactId>jorbis</artifactId>
            <version>0.0.17.4</version>
            <scope>system</scope>
            <systemPath>${libs.classes.path}/jorbis-0.0.17.4.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.smadja</groupId>
            <artifactId>JVstHost</artifactId>
            <version>1.0</version>
            <scope>system</scope>
            <systemPath>${libs.classes.path}/JVstHost.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.googlecode.soundlibs</groupId>
            <artifactId>mp3spi</artifactId>
            <version>1.9.5.4</version>
            <scope>system</scope>
            <systemPath>${libs.classes.path}/mp3spi-1.9.5.4.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.googlecode.soundlibs</groupId>
            <artifactId>tritonus-share</artifactId>
            <version>0.3.7.4</version>
            <scope>system</scope>
            <systemPath>${libs.classes.path}/tritonus-share-0.3.7.4.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.googlecode.soundlibs</groupId>
            <artifactId>vorbisspi</artifactId>
            <version>1.0.3.3</version>
            <scope>system</scope>
            <systemPath>${libs.classes.path}/vorbisspi-1.0.3.3.jar</systemPath>
        </dependency>
        <dependency>
            <groupId>com.ebanina</groupId>
            <artifactId>vst3host</artifactId>
            <version>1.0</version>
            <scope>system</scope>
            <systemPath>${libs.classes.path}/vst3host.jar</systemPath>
        </dependency>

        <dependency>
            <groupId>commons-io</groupId>
            <artifactId>commons-io</artifactId>
            <version>2.6</version>
            <scope>system</scope>
            <systemPath>${libs.classes.path}/ebanina-std-utils.jar</systemPath>
        </dependency>
    </dependencies>

    <build>
        <directory>out</directory>

        <!-- Исходники -->
        <sourceDirectory>../../../src</sourceDirectory>

        <!-- Тесты -->
        <testSourceDirectory>../../../test</testSourceDirectory>

        <plugins>
            <!-- Компиляция -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.12.1</version>
                <configuration>
                    <source>17</source>
                    <target>17</target>
                </configuration>
            </plugin>

            <!-- Основной JAR с MANIFEST -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.4.1</version>
                <configuration>
                    <archive>
                        <manifest>
                            <mainClass>rf.ebanina.Start</mainClass>
                            <addClasspath>true</addClasspath>
                            <classpathPrefix>libraries/classes/</classpathPrefix>
                        </manifest>
                        <manifestEntries>
                            <Class-Path>
                                libraries\classes\ebanina-std-utils.jar
                                libraries/classes/JVstHost.jar libraries/classes/vst3host.jar
                                libraries/classes/jlayer-1.0.1.4.jar libraries/classes/mp3spi-1.9.5.4.jar
                                libraries/classes/ebanina-mod-api.jar libraries/classes/jorbis-0.0.17.4.jar
                                libraries/classes/lastfm-java-0.1.2.jar libraries/classes/vorbisspi-1.0.3.3.jar
                                libraries/classes/ebanina-audio-player.jar libraries/classes/tritonus-share-0.3.7.4.jar
                                libraries/modules/javafx-swt.jar libraries/modules/javafx.web.jar
                                libraries/modules/jna-5.14.0.jar libraries/modules/untitled10.jar
                                libraries/modules/javafx.base.jar libraries/modules/javafx.fxml.jar
                                libraries/modules/javafx.media.jar libraries/modules/javafx.swing.jar
                                libraries/modules/jsoup-1.10.1.jar libraries/modules/mp3agic-0.9.1.jar
                                libraries/modules/commons-io-2.6.jar libraries/modules/jfoenix-9.0.10.jar
                                libraries/modules/javafx.controls.jar libraries/modules/javafx.graphics.jar
                                libraries/modules/jave-core-2.4.2.jar libraries/modules/byte-buddy-1.17.8.jar
                                libraries/modules/controlsfx-11.1.2.jar libraries/modules/jnativehook-2.2.2.jar
                                libraries/modules/lastfm-java-0.1.2.jar libraries/modules/testfx-core-4.0.18.jar
                                libraries/modules/assertj-core-3.27.6.jar libraries/modules/jna-platform-5.14.0.jar
                                libraries/modules/mockito-core-5.20.0.jar libraries/modules/testfx-junit-4.0.18.jar
                                libraries/modules/mockito-inline-5.2.0.jar libraries/modules/testfx-junit5-4.0.18.jar
                                libraries/modules/commons-logging-1.3.4.jar libraries/modules/junit-jupiter-6.0.0-M2.jar
                                libraries/modules/byte-buddy-agent-1.17.8.jar libraries/modules/junit-jupiter-api-6.0.0-M2.jar
                                libraries/modules/mockito-junit-jupiter-5.20.0.jar libraries/modules/junit-jupiter-engine-6.0.0-M2.jar
                                libraries/modules/junit-jupiter-params-6.0.0-M2.jar libraries/modules/junit-platform-console-standalone-1.10.0.jar</Class-Path>
                        </manifestEntries>
                    </archive>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <version>2.6</version>
                <executions>
                    <!-- Копировать папку libraries -->
                    <execution>
                        <id>copy-libraries</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>out/libraries</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${libs.path}</directory>

                                    <includes>
                                        <include>**/*</include>
                                        <include>**/</include>
                                    </includes>

                                    <targetPath></targetPath>
                                    <filtering>false</filtering>

                                    <excludes>
                                        <exclude>**/*test*.jar</exclude>
                                        <exclude>**/testfx*.jar</exclude>
                                        <exclude>**/mockito*.jar</exclude>
                                        <exclude>**/junit*.jar</exclude>
                                        <exclude>**/assertj*.jar</exclude>
                                        <exclude>**/byte*.jar</exclude>
                                    </excludes>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>

                    <!-- Копирование готового launch.bat -->
                    <execution>
                        <id>copy-launch-bat</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>out</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>script/win</directory>
                                    <includes>
                                        <include>launch.bat</include>
                                    </includes>
                                    <filtering>false</filtering>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>

                    <!-- Копировать папку res -->
                    <execution>
                        <id>copy-resources</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>out/res</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${resources.path}</directory>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>

                    <!-- Копируем структуру папки cache БЕЗ файлов -->
                    <execution>
                        <id>copy-cache-structure</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>out/cache</outputDirectory>
                            <resources>
                                <!-- Копируем ВСЮ папку cache -->
                                <resource>
                                    <directory>${cache.path}</directory>
                                    <!-- НЕ исключаем ничего - копируем всё -->
                                </resource>
                            </resources>
                            <!-- Файлы удалим ОТДЕЛЬНО после копирования -->
                            <overwrite>true</overwrite>
                        </configuration>
                    </execution>

                    <execution>
                        <id>delete-txt-files</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>out/cache</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>out/cache</directory>
                                    <excludes>
                                        <exclude>shared.txt</exclude>
                                        <exclude>cache/history.txt</exclude>
                                        <exclude>**/*.txt</exclude>
                                    </excludes>
                                </resource>
                            </resources>
                            <overwrite>true</overwrite>
                        </configuration>
                    </execution>

                    <!-- Копировать папку license -->
                    <execution>
                        <id>copy-license</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>out/license</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${license.path}</directory>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>

                    <!-- Копировать папку config -->
                    <execution>
                        <id>copy-config</id>
                        <phase>package</phase>
                        <goals>
                            <goal>copy-resources</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>out/config</outputDirectory>
                            <resources>
                                <resource>
                                    <directory>${config.path}</directory>
                                </resource>
                            </resources>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>