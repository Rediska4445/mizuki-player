<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="background" alignment="TOP_CENTER" prefHeight="450.0" prefWidth="800.0" style="-fx-background-color: #1e1e1e;" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="rf.ebanina.UI.Editors.Player.Controller">
    <spacing>15</spacing>
    <padding>
        <Insets bottom="15" left="20" right="20" top="20" />
    </padding>

    <Label fx:id="main_text" style="-fx-font-size: 32px; -fx-font-weight: 700; -fx-text-fill: #2a3e69;" text="Host" />

    <TabPane fx:id="tabPane" style="-fx-background-color: #1e1e1e;" prefHeight="370" prefWidth="760" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
        <tabs>
            <fx:include fx:id="vstPlugins" source="tabs/AudioPlugins.fxml" />
            <fx:include fx:id="IAudioPlugins" source="tabs/AudioEffects.fxml" />
            <fx:include fx:id="settings" source="tabs/Settings.fxml" />
            <fx:include fx:id="automation" source="tabs/Automation.fxml" />
        </tabs>
    </TabPane>
</VBox>
